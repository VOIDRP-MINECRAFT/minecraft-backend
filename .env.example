APP_NAME=VoidRP Account API
API_V1_PREFIX=/api/v1
APP_ENV=development
DEBUG=true

DATABASE_URL=postgresql+psycopg://voidrp:password@localhost:5432/voidrp_accounts

JWT_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
EMAIL_TOKEN_EXPIRE_HOURS=24

CORS_ALLOW_ORIGINS=["http://localhost:5173","https://void-rp.ru"]
EASYDONATE_SHOP_KEY=
EASYDONATE_SERVER_ID=

EMAIL_FROM=noreply@void-rp.ru
EMAIL_BACKEND=logging

PLAY_TICKET_EXPIRE_MINUTES=15
GAME_AUTH_SHARED_SECRET=CHANGE_ME_TO_LONG_RANDOM_SECRET_FOR_GAME_BRIDGE
ADMIN_API_SECRET=CHANGE_ME_TO_LONG_RANDOM_SECRET
LAUNCHER_HMAC_SECRET=CHANGE_ME_TO_LONG_RANDOM_SECRET_FOR_LAUNCHER_PROOF

PLAY_TICKET_EXPIRE_MINUTES=720

REDIS_URL=redis://127.0.0.1:6379/0
REDIS_PREFIX=voidrp
REDIS_DEFAULT_TTL_SECONDS=30


MINECRAFT_SERVER_HOST=play.void-rp.ru
MINECRAFT_SERVER_PORT=25565

RCON_HOST=
RCON_PORT=
RCON_PASSWORD=

YANDEX_METRIKA_TOKEN=
YANDEX_METRIKA_COUNTER_ID=